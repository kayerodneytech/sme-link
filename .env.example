# Standard names used for local development.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# The app also accepts Vercel's project-prefixed public names:
# NEXT_PUBLIC_sme_link_SUPABASE_URL
# NEXT_PUBLIC_sme_link_SUPABASE_PUBLISHABLE_KEY
# NEXT_PUBLIC_sme_link_SUPABASE_ANON_KEY
#
# Database passwords, JWT secrets and service-role keys are server secrets.
# Do not copy them into NEXT_PUBLIC variables or commit them to this repository.
